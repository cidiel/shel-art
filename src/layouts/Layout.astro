---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Shel's Art",
  description = "Original oil paintings and prints",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="nav-wordmark">Shel's Art</a>
      <ul class="nav-links">
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/shop">Shop</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <p>&copy; {new Date().getFullYear()} Shel's Art &nbsp;&middot;&nbsp; All rights reserved.</p>
    </footer>
  </body>
</html>
